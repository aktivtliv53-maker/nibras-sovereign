# ============================================================================
# [الطبقة 1] ArabicNormalizer - التطبيع العربي الذكي
# ============================================================================

class ArabicNormalizer:
    TASHKEEL_RE = re.compile(r'[\u064B-\u0652\u0670]')
    TATWEEL_RE = re.compile(r'ـ')
    NON_ARABIC_RE = re.compile(r'[^\u0621-\u064A\u0640\u064B-\u0652\u0670\s]')

    @classmethod
    def strip_non_arabic(cls, text: str) -> str:
        return cls.NON_ARABIC_RE.sub(' ', text)

    @classmethod
    def normalize_for_lookup(cls, text: str) -> str:
        """
        نسخة مهيأة للبحث المعجمي:
        - إزالة التشكيل (بما فيها الشدة)
        - إزالة التطويل
        - توحيد الألف والهمزات
        - توحيد ى -> ي
        - ؤ -> و
        - ئ -> ي
        - إبقاء ة كما هي أولًا ثم نسخة بديلة لاحقًا عند الحاجة
        """
        if not text:
            return ""

        text = cls.TATWEEL_RE.sub('', text)
        text = cls.TASHKEEL_RE.sub('', text)

        replacements = {
            'أ': 'ا', 'إ': 'ا', 'آ': 'ا',
            'ؤ': 'و', 'ئ': 'ي',
            'ى': 'ي'
        }
        for src, dst in replacements.items():
            text = text.replace(src, dst)

        text = re.sub(r'\s+', ' ', text).strip()
        return text

    @classmethod
    def normalize_for_geometry(cls, text: str) -> str:
        """
        نسخة مهيأة للحساب الهندسي:
        - نُبقي الشدة لأنها تُحسب ×2
        - نزيل باقي التشكيل
        - نزيل التطويل
        - نبقي الحروف العربية والشدة والمسافات
        """
        if not text:
            return ""

        text = cls.TATWEEL_RE.sub('', text)

        # إزالة كل التشكيل ما عدا الشدة
        text = re.sub(r'[\u064B-\u064C\u064D-\u0652\u0670]', '', text)
        # ملاحظة: الشدة U+0651 تبقى

        # إزالة غير العربي مع إبقاء الشدة والمسافات
        text = re.sub(r'[^\u0621-\u064A\u0651\s]', ' ', text)
        text = re.sub(r'\s+', ' ', text).strip()
        return text

    @classmethod
    def tokenize(cls, text: str):
        clean = cls.strip_non_arabic(text)
        clean = re.sub(r'\s+', ' ', clean).strip()
        if not clean:
            return []
        return clean.split()

# ============================================================================
# [الطبقة 2] MorphoLogicStemmer - المولد/المجرد الصرفي التقريبي
# ============================================================================

class MorphoLogicStemmer:
    """
    ليس محللًا صرفيًا أكاديميًا، بل مُجرّد ذكي يخدم نبراس:
    - يزيل سوابق شائعة
    - يزيل لواحق شائعة
    - يبني مرشحين متعددة
    - يحاول التقاط base_form أقرب
    """

    PREFIXES = [
        "وال", "فال", "بال", "كال", "ولل", "فلل", "لل",
        "ال", "و", "ف", "ب", "ك", "ل", "س"
    ]

    SUFFIXES = [
        "يات", "هات", "كما", "هما", "كم", "كن", "هم", "هن", "نا",
        "تان", "تين", "ات", "ون", "ين", "ان", "وا", "تم", "تن",
        "ه", "ها", "ة", "ي", "ك", "ا", "ن"
    ]

    @classmethod
    def normalize_word(cls, word: str) -> str:
        return ArabicNormalizer.normalize_for_lookup(word)

    @classmethod
    def _strip_prefixes(cls, word: str):
        candidates = {word}
        changed = True
        while changed:
            changed = False
            new_set = set(candidates)
            for w in list(candidates):
                for p in cls.PREFIXES:
                    if w.startswith(p) and len(w) - len(p) >= 3:
                        stripped = w[len(p):]
                        if stripped not in new_set:
                            new_set.add(stripped)
                            changed = True
            candidates = new_set
        return candidates

    @classmethod
    def _strip_suffixes(cls, word: str):
        candidates = {word}
        changed = True
        while changed:
            changed = False
            new_set = set(candidates)
            for w in list(candidates):
                for s in cls.SUFFIXES:
                    if w.endswith(s) and len(w) - len(s) >= 3:
                        stripped = w[:-len(s)]
                        if stripped not in new_set:
                            new_set.add(stripped)
                            changed = True
            candidates = new_set
        return candidates

    @classmethod
    def _pattern_candidates(cls, word: str):
        """
        بعض الأوزان التقريبية المفيدة:
        - متفعل / متفعلات -> جذر تقريبي
        - مستفعل -> حذف مست
        - تفعيل -> حذف ت أولى/ياء وسطى تقريبًا
        - مفعول -> حذف م/واو
        """
        cands = set()
        w = word

        # مستفعل -> حذف مست
        if w.startswith("مست") and len(w) >= 6:
            cands.add(w[3:])

        # استفعل -> حذف است
        if w.startswith("است") and len(w) >= 6:
            cands.add(w[3:])

        # متفعل / متفعلات
        if w.startswith("مت") and len(w) >= 5:
            cands.add(w[2:])

        # مفعول / مفعلة / مفعّل تقريبًا
        if w.startswith("م") and len(w) >= 4:
            cands.add(w[1:])

        # تفعيل / تفعّل تقريبًا
        if w.startswith("ت") and len(w) >= 4:
            cands.add(w[1:])

        # إزالة واو داخلية في وزن مفعول تقريبًا
        if len(w) >= 4:
            for i in range(1, len(w)-1):
                if w[i] == 'و':
                    cands.add(w[:i] + w[i+1:])

        # إزالة ياء داخلية في أوزان فعيل/تفعيل تقريبًا
        if len(w) >= 4:
            for i in range(1, len(w)-1):
                if w[i] == 'ي':
                    cands.add(w[:i] + w[i+1:])

        # إذا انتهت بتاء مربوطة -> نسخة بهاء ونسخة بدونها
        if w.endswith("ة") and len(w) > 3:
            cands.add(w[:-1])
            cands.add(w[:-1] + "ه")

        return {c for c in cands if len(c) >= 3}

    @classmethod
    def generate_candidates(cls, word: str):
        """
        يعيد قائمة مرشحين مرتبة تقريبية من الأقوى إلى الأضعف.
        """
        base = cls.normalize_word(word)
        if not base:
            return []

        candidates = []
        seen = set()

        def add(x):
            if x and len(x) >= 3 and x not in seen:
                seen.add(x)
                candidates.append(x)

        # الأصل
        add(base)

        # بدائل ة
        if base.endswith("ة"):
            add(base[:-1])
            add(base[:-1] + "ه")

        # تجريد السوابق واللواحق
        prefix_stripped = cls._strip_prefixes(base)
        all_stage = set(prefix_stripped)

        for p in list(prefix_stripped):
            all_stage.update(cls._strip_suffixes(p))

        for item in list(all_stage):
            add(item)

        # مرشحات الأوزان
        pattern_pool = set()
        for item in list(all_stage):
            pattern_pool.update(cls._pattern_candidates(item))

        for item in pattern_pool:
            add(item)

        # تقليص ثلاثي/رباعي تقريبي
        for item in list(candidates):
            if len(item) > 4:
                add(item[:4])
            if len(item) > 3:
                add(item[:3])

        # إزالة "ال" أخيرة احتياطية
        final_extra = []
        for item in candidates:
            if item.startswith("ال") and len(item) > 4:
                final_extra.append(item[2:])
        for item in final_extra:
            add(item)

        return candidates

