class ActivationGate(tk.Toplevel):
    def __init__(self, master):
        super().__init__(master)
        self.title("🔐 بروتوكول التفعيل")
        self.geometry("420x220")
        self.configure(bg="#001818")
        self.resizable(False, False)
        self.grab_set()
        self.result = False

        self.protocol("WM_DELETE_WINDOW", self._deny)

        frame = tk.Frame(self, bg="#001818")
        frame.pack(expand=True, fill="both", padx=20, pady=20)

        tk.Label(
            frame,
            text="🏛️ بروتوكول 58-58",
            font=("Arial", 16, "bold"),
            fg="#88ff88",
            bg="#001818"
        ).pack(pady=(0, 10))

        tk.Label(
            frame,
            text="أدخل كود التفعيل لفتح محراب نبراس الطير",
            font=("Arial", 10),
            fg="#c8ffd1",
            bg="#001818"
        ).pack()

        self.entry = tk.Entry(
            frame,
            justify="center",
            font=("Consolas", 16, "bold"),
            bg="#002626",
            fg="#ffff88",
            insertbackground="white",
            relief="flat"
        )
        self.entry.pack(pady=15, ipadx=10, ipady=6)
        self.entry.focus_set()

        btns = tk.Frame(frame, bg="#001818")
        btns.pack(pady=5)

        tk.Button(
            btns,
            text="تفعيل",
            command=self._approve,
            bg="#005522",
            fg="white",
            font=("Arial", 10, "bold"),
            padx=18
        ).pack(side="left", padx=8)

        tk.Button(
            btns,
            text="إغلاق",
            command=self._deny,
            bg="#330000",
            fg="white",
            font=("Arial", 10),
            padx=18
        ).pack(side="left", padx=8)

        self.bind("<Return>", lambda e: self._approve())

    def _approve(self):
        code = self.entry.get().strip()
        if code == ACTIVATION_CODE:
            self.result = True
            self.destroy()
        else:
            messagebox.showwarning("تنبيه", "الكود غير مطابق لبروتوكول 58-58")

    def _deny(self):
        self.result = False
        self.destroy()

