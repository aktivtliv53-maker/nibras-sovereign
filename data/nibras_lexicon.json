# [الطبقة 3] LexiconManager - مدير المعجم الخارجي الذكي
# ============================================================================

class LexiconManager:
    def __init__(self, filename=LEXICON_FILE):
        self.filename = filename
        self.data = []
        self.name_index = {}
        self.base_index = {}
        self.alias_index = {}
        self.load_lexicon()

    def _default_seed(self):
        return [
            {
                "name": "دبر",
                "base_form": "دبر",
                "orbit": "وعي",
                "orbit_weight": 1.35,
                "weight": 1.25,
                "symbol": "◈",
                "aliases": ["تدبر", "مدبر", "يدبر", "دابر"],
                "tags": ["reflection", "insight", "order"],
                "source_hint": "seed"
            },
            {
                "name": "رحم",
                "base_form": "رحم",
                "orbit": "فطرة",
                "orbit_weight": 1.40,
                "weight": 1.40,
                "symbol": "✦",
                "aliases": ["رحمن", "رحيم", "رحمة"],
                "tags": ["mercy", "origin", "nurture"],
                "source_hint": "seed"
            },
            {
                "name": "فتح",
                "base_form": "فتح",
                "orbit": "تمكين",
                "orbit_weight": 1.50,
                "weight": 1.35,
                "symbol": "⚡",
                "aliases": ["يفتح", "فتحا", "فاتح"],
                "tags": ["opening", "ease", "arrival"],
                "source_hint": "seed"
            }
        ]

    def _ensure_file_exists(self):
        if not os.path.exists(self.filename):
            seed = self._default_seed()
            with open(self.filename, 'w', encoding='utf-8') as f:
                json.dump(seed, f, ensure_ascii=False, indent=2)

    def _safe_load_json(self):
        self._ensure_file_exists()
        try:
            with open(self.filename, 'r', encoding='utf-8') as f:
                loaded = json.load(f)
                if isinstance(loaded, list):
                    return loaded
                return self._default_seed()
        except (json.JSONDecodeError, OSError):
            return self._default_seed()

    def _normalize_entry(self, entry):
        """
        تطبيع مدخل واحد مع مرونة في الحقول.
        """
        if not isinstance(entry, dict):
            return None

        name = ArabicNormalizer.normalize_for_lookup(str(entry.get("name", "")).strip())
        base_form = ArabicNormalizer.normalize_for_lookup(str(entry.get("base_form", name)).strip())

        if not name and not base_form:
            return None

        if not name:
            name = base_form
        if not base_form:
            base_form = name

        orbit = str(entry.get("orbit", "وعي")).strip()
        if orbit not in ORBIT_META:
            orbit = "وعي"

        orbit_weight = entry.get("orbit_weight", ORBIT_META[orbit]["weight"])
        try:
            orbit_weight = float(orbit_weight)
        except (ValueError, TypeError):
            orbit_weight = ORBIT_META[orbit]["weight"]

        weight = entry.get("weight", 1.0)
        try:
            weight = float(weight)
        except (ValueError, TypeError):
            weight = 1.0

        symbol = str(entry.get("symbol", ORBIT_META[orbit]["symbol"])).strip() or ORBIT_META[orbit]["symbol"]

        aliases = entry.get("aliases", [])
        if not isinstance(aliases, list):
            aliases = []
        aliases = [ArabicNormalizer.normalize_for_lookup(str(a).strip()) for a in aliases if str(a).strip()]
        aliases = list(dict.fromkeys([a for a in aliases if a]))  # dedupe preserving order

        tags = entry.get("tags", [])
        if not isinstance(tags, list):
            tags = []

        return {
            "name": name,
            "base_form": base_form,
            "orbit": orbit,
            "orbit_weight": orbit_weight,
            "weight": weight,
            "symbol": symbol,
            "aliases": aliases,
            "tags": tags,
            "source_hint": entry.get("source_hint", "manual"),
            "notes": entry.get("notes", "")
        }

    def _build_indexes(self):
        self.name_index.clear()
        self.base_index.clear()
        self.alias_index.clear()

        for entry in self.data:
            self.name_index[entry["name"]] = entry
            self.base_index[entry["base_form"]] = entry
            for alias in entry.get("aliases", []):
                self.alias_index[alias] = entry

    def load_lexicon(self):
        raw = self._safe_load_json()
        cleaned = []

        for entry in raw:
            norm = self._normalize_entry(entry)
            if norm:
                cleaned.append(norm)

        # إذا خرج فارغًا لأي سبب
        if not cleaned:
            cleaned = [self._normalize_entry(e) for e in self._default_seed()]
            cleaned = [e for e in cleaned if e]

        self.data = cleaned
        self._build_indexes()
        return self.data

    def reload(self):
        return self.load_lexicon()

    def count(self):
        return len(self.data)

    def _fallback_hint_entry(self, candidate: str):
        orbit = ORBIT_HINTS.get(candidate)
        if not orbit:
            return None

        return {
            "name": candidate,
            "base_form": candidate,
            "orbit": orbit,
            "orbit_weight": ORBIT_META[orbit]["weight"],
            "weight": 0.35,
            "symbol": ORBIT_META[orbit]["symbol"],
            "aliases": [],
            "tags": ["hint"],
            "source_hint": "hint",
            "notes": "generated from hint map"
        }

    def lookup(self, word: str):
        """
        بحث ذكي:
        1) مباشر على الاسم
        2) مباشر على base_form
        3) على aliases
        4) مرشحات stemmer
        5) hint fallback
        """
        normalized = ArabicNormalizer.normalize_for_lookup(word)
        if not normalized:
            return None

        # مباشر
        if normalized in self.name_index:
            return self.name_index[normalized]
        if normalized in self.base_index:
            return self.base_index[normalized]
        if normalized in self.alias_index:
            return self.alias_index[normalized]

        # مرشحات اشتقاق
        candidates = MorphoLogicStemmer.generate_candidates(normalized)
        for cand in candidates:
            if cand in self.name_index:
                return self.name_index[cand]
            if cand in self.base_index:
                return self.base_index[cand]
            if cand in self.alias_index:
                return self.alias_index[cand]

        # fallback hint
        for cand in candidates:
            hint = self._fallback_hint_entry(cand)
            if hint:
                return hint

        return None

