    def _bar(self, value, max_value, width=28):
        if max_value <= 0:
            return ""
        ratio = min(max(value / max_value, 0), 1)
        filled = max(1, int(ratio * width)) if value > 0 else 0
        return "█" * filled

    def _render_single_result(self, widget, res, label):
        widget.insert(tk.END, f"💎 المقام {label}: [{res['text']}]\n", "gold")
        widget.insert(
            tk.END,
            f"   ⚡ الموجة الكلية: {res['total_wave']:+.2f} | المدار الغالب: {res['dominant_orbit']} {res['orbit_symbol']}\n",
            "emerald"
        )
        widget.insert(
            tk.END,
            f"   🧬 البصمة الموقعة: {res['signed_signature']:+.2f} | البصمة المطلقة: {res['absolute_signature']:.2f}\n",
            "cyan"
        )
        widget.insert(
            tk.END,
            f"   👑 الحروف السيادية: {res['sovereign_count']} | عدد الكلمات: {res['word_count']}\n",
            "soft"
        )

        # توزيع المدارات
        widget.insert(tk.END, "   🪐 خارطة المدارات:\n", "lime")
        for orbit, count in res["orbit_counter"].most_common():
            symbol = ORBIT_META[orbit]["symbol"]
            widget.insert(tk.END, f"      • {orbit:<8} {symbol} × {count}\n")

        # الكلمات
        widget.insert(tk.END, "   🔬 تشريح الكلمات:\n", "lime")
        for d in res["details"]:
            widget.insert(
                tk.END,
                (
                    f"      • {d['word']:<16} -> {d['symbol']} {d['orbit']:<8} | "
                    f"حروف: {d['letter_energy']:+.2f} | "
                    f"معجم: {d['lex_weight']:+.2f} | "
                    f"مدار: {d['orbit_influence']:+.2f} | "
                    f"المحصلة: {d['wave']:+.2f}\n"
                )
            )

        widget.insert(tk.END, f"   🕊️ المستشار السيادي:\n      {res['advisor']}\n", "warning")

    def _render_comparison(self, cmp_data):
        res1 = cmp_data["res1"]
        res2 = cmp_data["res2"]

        self.display.delete("1.0", tk.END)

        self._render_single_result(self.display, res1, "الأول")
        self.display.insert(tk.END, "\n" + "═" * 100 + "\n\n")
        self._render_single_result(self.display, res2, "الثاني")
        self.display.insert(tk.END, "\n" + "═" * 100 + "\n\n")

        # ميزان المقارنة
        self.display.insert(tk.END, "⚖️ ميزان المقارنة\n", "gold")
        self.display.insert(tk.END, f"   • الفارق الطاقي: {cmp_data['diff']:+.2f}\n", "magenta")
        self.display.insert(tk.END, f"   • الفارق المطلق: {cmp_data['abs_diff']:.2f}\n", "magenta")
        self.display.insert(tk.END, f"   • زوج المدارات: {cmp_data['pair_key']}\n", "soft")
        self.display.insert(tk.END, f"   • الملخص: {cmp_data['summary']}\n", "soft")

        # Bar Chart نصي
        self.display.insert(tk.END, "\n📊 الرسم البياني النصي للرنين\n", "gold")
        max_v = max(abs(res1["total_wave"]), abs(res2["total_wave"]), 1)
        b1 = self._bar(abs(res1["total_wave"]), max_v)
        b2 = self._bar(abs(res2["total_wave"]), max_v)
        bd = self._bar(abs(cmp_data["diff"]), max_v)

        self.display.insert(tk.END, f"   النص الأول   : {b1:<28} {res1['total_wave']:+.2f}\n", "emerald")
        self.display.insert(tk.END, f"   النص الثاني  : {b2:<28} {res2['total_wave']:+.2f}\n", "cyan")
        self.display.insert(tk.END, f"   الفارق       : {bd:<28} {cmp_data['diff']:+.2f}\n", "magenta")

        # الجذور/المداخل المشتركة
        self.display.insert(tk.END, "\n🔗 الروابط المعجمية\n", "gold")
        shared = ", ".join(cmp_data["shared_bases"]) if cmp_data["shared_bases"] else "لا توجد روابط مشتركة صريحة"
        only1 = ", ".join(cmp_data["only1_bases"][:12]) if cmp_data["only1_bases"] else "—"
        only2 = ", ".join(cmp_data["only2_bases"][:12]) if cmp_data["only2_bases"] else "—"

        self.display.insert(tk.END, f"   • المشترك: {shared}\n", "soft")
        self.display.insert(tk.END, f"   • خاص بالأول: {only1}\n", "soft")
        self.display.insert(tk.END, f"   • خاص بالثاني: {only2}\n", "soft")

    def _render_letter_comparison(self, cmp_data):
        self.letter_display.delete("1.0", tk.END)

        res1 = cmp_data["res1"]
        res2 = cmp_data["res2"]

        self.letter_display.insert(tk.END, "🔠 المقارنة الحرفية التفصيلية\n\n", "gold")

        def render_word_details(label, res):
            self.letter_display.insert(tk.END, f"💠 المقام {label}: [{res['text']}]\n", "emerald")
            for d in res["details"]:
                self.letter_display.insert(
                    tk.END,
                    f"   • {d['word']}  ←  {d['base_form']}  | {d['orbit']} {d['symbol']}\n",
                    "cyan"
                )
                if d["char_breakdown"]:
                    for c in d["char_breakdown"]:
                        self.letter_display.insert(
                            tk.END,
                            f"      - {c['display']:<10} {c['value']:+.2f}\n"
                        )
                else:
                    self.letter_display.insert(tk.END, "      - لا توجد تفاصيل حرفية\n")
                self.letter_display.insert(tk.END, "\n")

        render_word_details("الأول", res1)
        self.letter_display.insert(tk.END, "═" * 90 + "\n\n")
        render_word_details("الثاني", res2)

    def process(self):
        text1 = self.ent1.get().strip()
        text2 = self.ent2.get().strip()

        if not text1 or not text2:
            messagebox.showwarning("تنبيه", "الرجاء إدخال المقامين أولًا.")
            return

        cmp_data = self.engine.compare_texts(text1, text2)
        self.last_comparison = cmp_data

        self._render_comparison(cmp_data)
        self._render_letter_comparison(cmp_data)

        # حفظ تلقائي في الأرشيف
        self.engine.save_comparison_to_archive(cmp_data)

        self.notebook.select(self.tab_results)

    def show_archive(self):
        data = self.engine.archive.load()

        win = tk.Toplevel(self.root)
        win.title("📜 أرشيف نبراس")
        win.geometry("1000x650")
        win.configure(bg="#001414")

        tk.Label(
            win,
            text=f"📜 أرشيف نبراس — آخر {len(data)} سجل",
            bg="#003333",
            fg="#88ff88",
            font=("Arial", 14, "bold")
        ).pack(fill="x", pady=(0, 8))

        box = scrolledtext.ScrolledText(
            win,
            bg="#000d0d",
            fg="#ccffcc",
            font=("Consolas", 10),
            bd=0,
            wrap="word"
        )
        box.pack(fill="both", expand=True, padx=10, pady=10)

        self._config_text_tags(box)

        if not data:
            box.insert(tk.END, "لا توجد سجلات محفوظة بعد.\n", "warning")
            return

        for i, item in enumerate(reversed(data), 1):
            box.insert(tk.END, f"[{i}] {item.get('timestamp', '')}\n", "gold")
            box.insert(tk.END, f"   • الأول : {item.get('text1', '')}\n")
            box.insert(tk.END, f"   • الثاني: {item.get('text2', '')}\n")
            box.insert(tk.END, f"   • موجة1 : {item.get('wave1', 0):+.2f} | موجة2: {item.get('wave2', 0):+.2f} | فرق: {item.get('diff', 0):+.2f}\n", "emerald")
            box.insert(tk.END, f"   • الغالب: {item.get('dominant1', '')} ↔ {item.get('dominant2', '')}\n", "cyan")
            shared = ", ".join(item.get("shared_bases", [])) if item.get("shared_bases") else "—"
            box.insert(tk.END, f"   • المشترك: {shared}\n", "soft")
            box.insert(tk.END, f"   • الملخص: {item.get('summary', '')}\n", "warning")
            box.insert(tk.END, "─" * 95 + "\n")

# ============================================================================
# [التشغيل الرئيسي]
# ============================================================================

def main():
    root = tk.Tk()
    root.withdraw()  # إخفاء مؤقت حتى يمر التفعيل

    gate = ActivationGate(root)
    root.wait_window(gate)

    if not gate.result:
        root.destroy()
        return

    root.deiconify()
    app = NibrasEmeraldGUI(root)
    root.mainloop()

if __name__ == "__main__":
    main()
