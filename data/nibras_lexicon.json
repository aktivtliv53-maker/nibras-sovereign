class SovereignAdvisor52:
    ADVICE_MAP = {
        "تمكين": "الطاقة الغالبة تحمل فتحًا ويسرًا. الأنسب الآن: الإقدام الهادئ، وتثبيت الخطوة، وفتح الباب المبارك.",
        "تزكية": "الطاقة الغالبة تحمل بناءً وتطهيرًا. الأنسب الآن: تهذيب المقصد، وتصفية النية، وتوسيع الخير في الداخل والخارج.",
        "وعي": "الطاقة الغالبة تحمل تبصرًا ونورًا. الأنسب الآن: التأمل الهادئ، وجمع المعنى، واتخاذ القرار من موضع صفاء.",
        "فطرة": "الطاقة الغالبة تحمل رحمةً ونماءً. الأنسب الآن: اللطف، والرعاية، وتغذية الأصل المبارك.",
        "يسر": "الطاقة الغالبة تحمل انسيابًا مباركًا. الأنسب الآن: اختيار الطريق الأخف نورًا، وترك ما لا يحتاج مشقة زائدة.",
        "سيادة": "الطاقة الغالبة تحمل حضورًا وتمركزًا. الأنسب الآن: تثبيت المقام، وضبط الإيقاع، والتقدم بثقة ساكنة.",
        "هداية": "الطاقة الغالبة تحمل بيانًا وسكينة. الأنسب الآن: الإصغاء للإشارة الواضحة، واتباع النور الأقرب.",
        "تحول": "الطاقة الغالبة تحمل نقلةً مباركة. الأنسب الآن: استقبال التحول بلين، وبناء المسار الجديد بثبات.",
        "كون": "الطاقة الغالبة تحمل اتساعًا وامتدادًا. الأنسب الآن: توسيع الرؤية، واحتضان الأفق الأرحب.",
        "حركة": "الطاقة الغالبة تحمل سريانًا وتقدمًا. الأنسب الآن: المبادرة الخفيفة، والاستمرار المنتظم، وتغذية الزخم المبارك.",
        "إدراك": "الطاقة الغالبة تحمل فهمًا وتجلّيًا. الأنسب الآن: ترتيب الفكرة، وربط الخيوط، وصناعة صورة أوضح.",
        "أزل": "الطاقة الغالبة تحمل ثباتًا ونورًا أصيلًا. الأنسب الآن: الرجوع إلى الأصل النقي، وتثبيت ما هو راسخ ومبارك."
    }

    def advise(self, dominant_orbit: str, orbit_counter: Counter):
        main = self.ADVICE_MAP.get(
            dominant_orbit,
            "الطاقة الحاضرة تحمل خيرًا متوازنًا. الأنسب الآن: المضي بلطف وثبات ونية مشرقة."
        )

        # مدار ثانوي لإثراء المشهد
        secondary = None
        common = orbit_counter.most_common(2)
        if len(common) > 1:
            secondary = common[1][0]

        if secondary and secondary in ORBIT_META:
            addon = f" والمدار المساند: {secondary} {ORBIT_META[secondary]['symbol']} ({ORBIT_META[secondary]['tone']})."
        else:
            addon = ""

        return main + addon

