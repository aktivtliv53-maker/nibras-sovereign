# [الطبقة 5] ArchiveManager - الأرشيف
# ============================================================================

class ArchiveManager:
    def __init__(self, filename=ARCHIVE_FILE):
        self.filename = filename

    def load(self):
        if not os.path.exists(self.filename):
            return []
        try:
            with open(self.filename, 'r', encoding='utf-8') as f:
                data = json.load(f)
                return data if isinstance(data, list) else []
        except (json.JSONDecodeError, OSError):
            return []

    def save_entry(self, entry: dict):
        data = self.load()
        data.append(entry)

        # حد أقصى معقول
        if len(data) > 200:
            data = data[-200:]

        try:
            with open(self.filename, 'w', encoding='utf-8') as f:
                json.dump(data, f, ensure_ascii=False, indent=2)
        except OSError:
            pass

# ============================================================================
# [الطبقة 6] NibrasCoreEngine - المحرك المركزي
# ============================================================================

class NibrasCoreEngine:
    def __init__(self):
        self.lexicon = LexiconManager()
        self.advisor = SovereignAdvisor52()
        self.archive = ArchiveManager()

    def _char_energy_breakdown(self, word: str):
        """
        حساب طاقة الحروف مع مراعاة:
        - الشدة: تضيف قيمة الحرف السابق مرة ثانية
        - boost خفيف للحروف السيادية
        """
        geo_word = ArabicNormalizer.normalize_for_geometry(word)
        breakdown = []
        total = 0.0

        prev_arabic_char = None

        for ch in geo_word:
            if ch == ' ':
                continue

            if ch == 'ّ':
                if prev_arabic_char:
                    base = LETTER_GEO.get(prev_arabic_char, 0.0)
                    total += base
                    breakdown.append({
                        "char": "ّ",
                        "display": f"شدّة({prev_arabic_char})",
                        "value": round(base, 2)
                    })
                continue

            val = LETTER_GEO.get(ch, 0.0)

            # boost سيادي خفيف جدًا حتى لا يطغى
            boost = 0.12 if ch in SOVEREIGN_LETTERS else 0.0
            val += boost

            total += val
            breakdown.append({
                "char": ch,
                "display": ch,
                "value": round(val, 2)
            })

            prev_arabic_char = ch

        return round(total, 2), breakdown

    def _derive_word_data(self, original_word: str):
        """
        يحلل كلمة واحدة:
        - طاقة الحروف
        - ربط معجمي
        - وزن المدار
        - الوزن الخاص بالمدخل
        - البصمة النهائية
        """
        letter_energy, char_breakdown = self._char_energy_breakdown(original_word)
        lex_entry = self.lexicon.lookup(original_word)

        if lex_entry:
            orbit = lex_entry.get("orbit", "وعي")
            symbol = lex_entry.get("symbol", ORBIT_META[orbit]["symbol"])
            base_form = lex_entry.get("base_form", "")
            lex_weight = float(lex_entry.get("weight", 1.0))
            orbit_weight = float(lex_entry.get("orbit_weight", ORBIT_META[orbit]["weight"]))
            source_hint = lex_entry.get("source_hint", "manual")
        else:
            orbit = "وعي"
            symbol = ORBIT_META[orbit]["symbol"]
            base_form = ArabicNormalizer.normalize_for_lookup(original_word)
            lex_weight = 0.0
            orbit_weight = ORBIT_META[orbit]["weight"]
            source_hint = "unmapped"

        # الصيغة النهائية المتوازنة:
        # final = طاقة الحروف + وزن المعجم + (وزن المدار - 1) * 0.75
        orbit_influence = (orbit_weight - 1.0) * 0.75
        final_wave = letter_energy + lex_weight + orbit_influence

        return {
            "word": original_word,
            "normalized": ArabicNormalizer.normalize_for_lookup(original_word),
            "base_form": base_form,
            "orbit": orbit,
            "symbol": symbol,
            "letter_energy": round(letter_energy, 2),
            "lex_weight": round(lex_weight, 2),
            "orbit_weight": round(orbit_weight, 2),
            "orbit_influence": round(orbit_influence, 2),
            "wave": round(final_wave, 2),
            "char_breakdown": char_breakdown,
            "source_hint": source_hint
        }

    def analyze_text(self, text: str):
        words = ArabicNormalizer.tokenize(text)
        details = []
        orbit_list = []
        base_forms = []
        sovereign_count = 0
        total_wave = 0.0

        for word in words:
            data = self._derive_word_data(word)
            details.append(data)
            orbit_list.append(data["orbit"])
            base_forms.append(data["base_form"])
            total_wave += data["wave"]

            # عدّ الحروف السيادية من النسخة الهندسية
            geo = ArabicNormalizer.normalize_for_geometry(word)
            for ch in geo:
                if ch in SOVEREIGN_LETTERS:
                    sovereign_count += 1

        orbit_counter = Counter(orbit_list)
        dominant_orbit = orbit_counter.most_common(1)[0][0] if orbit_counter else "وعي"
        orbit_symbol = ORBIT_META.get(dominant_orbit, {}).get("symbol", "✨")

        # بصمة موقعة + بصمة مطلقة
        signed_signature = round(total_wave * 3.7 + sovereign_count * 1.5, 2)
        absolute_signature = round(abs(total_wave) * 3.7 + sovereign_count * 1.5, 2)

        advisor_text = self.advisor.advise(dominant_orbit, orbit_counter)

        return {
            "text": text,
            "words": words,
            "details": details,
            "word_count": len(words),
            "total_wave": round(total_wave, 2),
            "dominant_orbit": dominant_orbit,
            "orbit_symbol": orbit_symbol,
            "orbit_counter": orbit_counter,
            "base_forms": base_forms,
            "unique_base_forms": sorted(set([b for b in base_forms if b])),
            "sovereign_count": sovereign_count,
            "signed_signature": signed_signature,
            "absolute_signature": absolute_signature,
            "advisor": advisor_text
        }

    def compare_texts(self, text1: str, text2: str):
        res1 = self.analyze_text(text1)
        res2 = self.analyze_text(text2)

        diff = round(res1["total_wave"] - res2["total_wave"], 2)
        abs_diff = round(abs(diff), 2)

        set1 = set(res1["unique_base_forms"])
        set2 = set(res2["unique_base_forms"])
        shared = sorted(set1 & set2)
        only1 = sorted(set1 - set2)
        only2 = sorted(set2 - set1)

        # قراءة غلبة مزدوجة
        pair_key = f"{res1['dominant_orbit']} ↔ {res2['dominant_orbit']}"

        comparison_summary = (
            f"المشهد المقارن يحمل: {res1['dominant_orbit']} {res1['orbit_symbol']} "
            f"في المقام الأول، و{res2['dominant_orbit']} {res2['orbit_symbol']} في المقام الثاني. "
            f"الفارق الحالي يساوي {diff:+.2f}، وهو فارق يصلح للتمييز الهادئ بين المقامين."
        )

        return {
            "res1": res1,
            "res2": res2,
            "diff": diff,
            "abs_diff": abs_diff,
            "shared_bases": shared,
            "only1_bases": only1,
            "only2_bases": only2,
            "pair_key": pair_key,
            "summary": comparison_summary
        }

    def save_comparison_to_archive(self, cmp_data: dict):
        res1 = cmp_data["res1"]
        res2 = cmp_data["res2"]

        entry = {
            "timestamp": datetime.now().isoformat(timespec="seconds"),
            "text1": res1["text"],
            "text2": res2["text"],
            "wave1": res1["total_wave"],
            "wave2": res2["total_wave"],
            "diff": cmp_data["diff"],
            "dominant1": res1["dominant_orbit"],
            "dominant2": res2["dominant_orbit"],
            "signature1": res1["absolute_signature"],
            "signature2": res2["absolute_signature"],
            "shared_bases": cmp_data["shared_bases"],
            "summary": cmp_data["summary"]
        }
        self.archive.save_entry(entry)

